# 安全生产管理系统 - 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# ========== 服务器配置 ==========
# 服务端口（默认：3001）
PORT=3001

# 运行环境（development / production）
NODE_ENV=development

# ========== JWT 配置 ==========
# JWT 密钥（⚠️ 生产环境必须修改为强密码！）
# 建议：至少32位随机字符串
JWT_SECRET=your-strong-jwt-secret-here-at-least-32-characters

# ========== 数据库配置 ==========
# MySQL 主机地址
DB_HOST=localhost

# MySQL 端口（默认：3306）
DB_PORT=3306

# MySQL 用户名
DB_USER=root

# MySQL 密码
DB_PASSWORD=your-database-password

# 数据库名称
DB_NAME=safety_system

# ========== CORS 配置 ==========
# 允许的跨域来源（逗号分隔，仅生产环境生效）
# 开发环境将允许所有来源
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://192.168.1.19

# ========== 其他配置 ==========
# 日志级别（debug / info / warn / error）
LOG_LEVEL=debug

# 请求超时时间（毫秒，默认：60000）
TIMEOUT=60000
